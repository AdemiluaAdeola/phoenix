# ─────────────────────────────────────────────────────────────────
# Phoenix Assessment Platform — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Supabase Table Names (defaults shown — change only if different) ──
VITE_SUPABASE_ASSESSMENTS_TABLE=assessments
VITE_SUPABASE_TESTIMONIALS_TABLE=testimonials
VITE_SUPABASE_READINESS_TABLE=readiness
VITE_SUPABASE_EXECUTION_FORMS_TABLE=execution_forms

# ── Email (Resend via Supabase Edge Function) ───────────────────
# The React app sends mail through the Supabase `send-email` function.
# Set these secrets in Supabase (Dashboard → Edge Functions → Secrets),
# NOT in this .env file:
#   RESEND_API_KEY=re_your_resend_api_key
#   RESEND_FROM_EMAIL=Phoenix Clear Insight <noreply@phoenixclearinsight.com>
#
# Deploy the function once:
#   supabase functions deploy send-email --project-ref your-project-ref
#
# Optional client-side fallback for local experiments only (not recommended):
# VITE_RESEND_API_KEY=re_your_resend_api_key
# VITE_RESEND_FROM_EMAIL=Phoenix Clear Insight <noreply@phoenixclearinsight.com>

# Local dev: route email through the Vite server proxy at /api/send-email
# VITE_EMAIL_API_URL=/api/send-email

# Until your domain is verified on Resend, keep sandbox mode enabled for local testing.
# Sends from onboarding@resend.dev to your Resend account email only.
# VITE_RESEND_USE_SANDBOX=true

# ── Kit / ConvertKit (via Supabase Edge Function) ─────────────────
# The app invokes the Supabase `convertkit-subscribe` function after the
# clarity assessment completes.
#
# Set these secrets in Supabase (Dashboard → Edge Functions → Secrets),
# NOT in this .env file:
#   CONVERTKIT_API_KEY=your-kit-api-key
#   CONVERTKIT_API_SECRET=your-kit-api-secret
#   CONVERTKIT_TAG_ID=20158486
#
# Optional archetype-specific tags:
#   CONVERTKIT_TAG_MOMENTUM=your-tag-id
#   CONVERTKIT_TAG_DREAMING=your-tag-id
#   CONVERTKIT_TAG_AWAKENING=your-tag-id
#
# Deploy the function once:
#   supabase functions deploy convertkit-subscribe --project-ref your-project-ref
#
# Client-side config should only pass the non-secret default tag ID:
VITE_CONVERTKIT_TAG_ID=20158486

# ─────────────────────────────────────────────────────────────────
# Phoenix Assessment Platform — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Supabase Table Names (defaults shown — change only if different) ──
VITE_SUPABASE_ASSESSMENTS_TABLE=assessments
VITE_SUPABASE_TESTIMONIALS_TABLE=testimonials
VITE_SUPABASE_READINESS_TABLE=readiness
VITE_SUPABASE_EXECUTION_FORMS_TABLE=execution_forms

# ── Email (Resend) ────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
VITE_RESEND_API_KEY=re_your_resend_api_key

# Sender address — domain MUST be verified at https://resend.com/domains
# Until verified, use: onboarding@resend.dev  (delivers to your own email only)
VITE_RESEND_FROM_EMAIL=Phoenix Clear Insight <noreply@phoenixclearinsight.com>

# ── Optional: Backend Email Proxy (Production-safe) ───────────────
# If set, all emails are routed through this endpoint instead of
# calling Resend directly from the browser (hides your API key).
# Leave blank to use the browser-side Resend client.
# VITE_EMAIL_API_URL=https://your-backend.com/api/send-email
